{
  "name": "digynotes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash ./scripts/restart-local-4300.sh",
    "dev:restart": "bash ./scripts/restart-local-4300.sh",
    "build": "prisma generate && next build",
    "lint": "eslint . --ignore-pattern .next --max-warnings=0",
    "start": "next start",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test --experimental-strip-types tests/*.test.mjs",
    "clean": "rm -rf .next node_modules/.cache",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"prisma/schema.prisma\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"prisma/schema.prisma\"",
    "typecheck": "prisma generate && tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@remotion/player": "^4.0.438",
    "@tailwindcss/typography": "^0.5.16",
    "@vercel/analytics": "^1.6.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.35.2",
    "gray-matter": "^4.0.3",
    "next": "14.0.4",
    "next-auth": "^4.24.13",
    "pg": "^8.18.0",
    "prisma": "^7.4.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.5.2",
    "react-markdown": "^9.0.3",
    "react-quill": "^2.0.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.0",
    "remotion": "^4.0.438",
    "sanitize-html": "^2.17.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sanitize-html": "^2.16.0",
    "autoprefixer": "^10.0.1",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
